# WeatherBot secrets — copy to .env and fill in. NEVER commit the real .env.
# Both values are bearer-style credentials (anyone holding them can act as you).

# OpenWeather API key (https://openweathermap.org/api). New keys can take up to
# ~2 hours to activate and may return 401 until then.
OPENWEATHER_API_KEY=

# Discord incoming webhook URL (Server Settings -> Integrations -> Webhooks).
# Treat like a password: anyone with this URL can post to your channel.
DISCORD_WEBHOOK_URL=

# Discord inbound gateway bot token (Developer Portal -> Applications ->
# (your app) -> Bot -> Reset Token). REQUIRED at startup — the process fails
# loud if it is missing. Also enable the privileged "Message Content Intent"
# in the same Bot settings page (see deploy/README.md). Treat like a password.
DISCORD_BOT_TOKEN=
